# PostgreSQL connection string
# Local Supabase: postgresql://postgres:postgres@localhost:54322/postgres
# Hosted Supabase: postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Set to "true" when DATABASE_URL points at a hosted instance (requires SSL)
DATABASE_SSL=false

# JWT secret — copy from Supabase → Project Settings → API → JWT Secret
JWT_SECRET=your-supabase-jwt-secret

# Port the API listens on
PORT=3001

# Allowed CORS origin (set to your frontend URL in production)
CORS_ORIGIN=http://localhost:5173
